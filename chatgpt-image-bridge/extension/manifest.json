{
  "manifest_version": 3,
  "name": "ChatGPT Image Bridge",
  "version": "1.1.3",
  "description": "Puente local para generar imagenes en ChatGPT desde tus agentes de terminal, reutilizando tu sesion ya logueada en Chrome.",
  "permissions": ["nativeMessaging", "downloads", "tabs", "alarms"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
